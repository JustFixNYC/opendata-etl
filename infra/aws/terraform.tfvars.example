# SPDX-License-Identifier: AGPL-3.0-only
# Copy to terraform.tfvars and adjust before terraform apply.
# Do not commit terraform.tfvars (may contain account-specific CIDRs).

# --- Parallel POC (profile: standard) — recommended starting point ---
project_name = "opendata-etl"
environment  = "poc"
aws_region   = "us-east-1"

# Restrict Dagster UI and admin access (replace with your office/VPN CIDR).
admin_cidr_blocks = ["203.0.113.0/24"]

api_ingress_cidr_blocks = ["0.0.0.0/0"]

postgres_instance_class = "db.t4g.medium"
postgres_engine_version = "16.6"

single_nat_gateway           = true
landing_lifecycle_expire_days = 90
landing_bucket_force_destroy  = true # ephemeral POC only; false in long-lived envs

create_orchestrator_instance = true
create_api_instance          = true # split FastAPI host (standard profile POC)

# --- Production-sized example (uncomment and adjust) ---
# environment               = "prod"
# postgres_instance_class   = "db.r6g.large"
# landing_bucket_force_destroy = false
# postgres_deletion_protection = true
