# Copy to .env in your deployment repo. Do not commit real .env files.

OPENDATA_FRAMEWORK_IMAGE=ghcr.io/example-org/opendata-etl:v0.1.0

POSTGRES_USER=opendata
POSTGRES_PASSWORD=opendata
POSTGRES_DB=opendata
POSTGRES_PORT=5432

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=opendata-landing

DAGSTER_PORT=3000
API_PORT=8000

OPENDATA_DEFINITIONS_MANIFEST_PATH=/workspace/definitions.yml
OPENDATA_DEFINITIONS_WORK_DIR=/workspace/data/definitions_work
OPENDATA_DAGSTER_DEFINITION_LOAD=clone
OPENDATA_DAGSTER_MATERIALIZE=full

# Optional when API routes execute real SQL.
# OPENDATA_API_ROLE_DSNS={"opendata_public_read":"postgresql://opendata_public_read:changeme@postgres:5432/opendata"}
# OPENDATA_API_KEYS_LOOKUP_DSN=postgresql://opendata:opendata@postgres:5432/opendata
