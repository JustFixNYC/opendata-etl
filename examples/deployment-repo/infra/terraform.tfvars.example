# Copy to terraform.tfvars in your deployment repo and adjust.
# Do not commit terraform.tfvars; it may contain account-specific CIDRs or image refs.

project_name = "opendata-etl"
environment  = "poc"
aws_region   = "us-east-1"

admin_cidr_blocks       = ["203.0.113.0/24"]
api_ingress_cidr_blocks = ["203.0.113.0/24"]

postgres_instance_class      = "db.t4g.medium"
single_nat_gateway           = true
landing_bucket_force_destroy = true

# Defaults use s3://<landing>/config/... after the module creates the bucket.
# orchestrator_runtime_bundle_s3_uri = "s3://my-config-bucket/config/orchestrator-runtime.tar.gz"
# orchestrator_manifest_s3_uri       = "s3://my-config-bucket/config/definitions.yml"

# Empty defaults to the module-created ECR repository with :poc.
# orchestrator_framework_image = "123456789012.dkr.ecr.us-east-1.amazonaws.com/opendata-etl-poc/framework:poc"

tags = {
  Service = "opendata-etl"
}
