# Reference env for standard-profile orchestrator (compose host).
# Bootstrapped EC2 instances build /opt/opendata-etl/.env from SSM at first boot;
# use this file as documentation when editing secrets out-of-band.
#
# Required at runtime (set by user_data or operator):
#   OPENDATA_FRAMEWORK_IMAGE=<ecr-url>:<tag>
#   DATABASE_URL=postgresql://...
#   OPENDATA_DEFINITIONS_MANIFEST_PATH=/opt/opendata-etl/definitions.yml
#
# Standard flags (also in SSM .../runtime/standard_env after terraform apply):
OPENDATA_LANDING_BACKEND=s3
OPENDATA_LOAD_BACKEND=s3_copy_rds
OPENDATA_DERIVED_RUNNER=docker
OPENDATA_EXTRACT_EXECUTOR=local
OPENDATA_DAGSTER_MATERIALIZE=full
OPENDATA_PG_OWNER_ROLE=opendata_admin
OPENDATA_S3_COPY_REGION=us-east-1

S3_BUCKET=REPLACE_LANDING_BUCKET
OPENDATA_DEFINITIONS_WORK_DIR=/var/lib/opendata-etl/definitions_work
OPENDATA_DAGSTER_DEFINITION_LOAD=clone
DAGSTER_HOME=/var/lib/opendata-etl/dagster_home

# Optional Slack (Step 12)
# OPENDATA_SLACK_TOKEN=
# OPENDATA_SLACK_CHANNEL=
