# Reference env for standard-profile API host.
# Live EC2 env files should be rendered from SSM or another secret store.

# Required at runtime:
#   OPENDATA_FRAMEWORK_IMAGE=<ecr-or-ghcr-url>:<tag>
#   DATABASE_URL=postgresql://opendata_admin:...@<rds-endpoint>:5432/opendata?sslmode=require
#   OPENDATA_API_KEYS_LOOKUP_DSN=postgresql://opendata_admin:...@<rds-endpoint>:5432/opendata?sslmode=require
#   OPENDATA_API_ROLE_DSNS={"opendata_public_read":"postgresql://...","opendata_ex_housing_read":"postgresql://..."}

OPENDATA_DEFINITIONS_MANIFEST_PATH=/opt/opendata-etl/definitions.yml
OPENDATA_DEFINITIONS_WORK_DIR=/var/lib/opendata-etl/definitions_work
OPENDATA_DAGSTER_DEFINITION_LOAD=clone

# Optional source / landing vars used when endpoint startup validates definition repos.
S3_BUCKET=REPLACE_LANDING_BUCKET
OPENDATA_S3_COPY_REGION=us-east-1
