{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opendata-etl.dev/schemas/derived_job.schema.json",
  "title": "Python derived job definition (derived_jobs/*.yml)",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "entrypoint", "tables"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Derived job id (listed in definitions[].enabled_datasets alongside dataset ids)."
    },
    "description": { "type": "string", "maxLength": 4000 },
    "entrypoint": {
      "type": "string",
      "minLength": 3,
      "maxLength": 256,
      "pattern": "^derived\\.[a-z][a-z0-9_]*:[a-z][a-z0-9_]*$",
      "description": "Import path under python/derived/ (e.g. derived.greeting_letter_counts:main)."
    },
    "schedule": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Cron expression in UTC for Dagster schedule (optional)."
    },
    "freshness_sla_hours": { "type": "number", "minimum": 0 },
    "schema_contract": {
      "type": "string",
      "enum": ["freeze", "evolve"]
    },
    "depends_on": {
      "type": "array",
      "description": "Dataset or derived job names within the same repo that must materialize first.",
      "items": { "type": "string", "minLength": 1, "maxLength": 128 },
      "uniqueItems": true
    },
    "tables": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/derivedTable" }
    }
  },
  "$defs": {
    "postgresIdentifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 63,
      "pattern": "^[a-z_][a-z0-9_]*$"
    },
    "column": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type"],
      "properties": {
        "name": { "$ref": "#/$defs/postgresIdentifier" },
        "type": {
          "type": "string",
          "enum": [
            "text",
            "bigint",
            "integer",
            "double",
            "numeric",
            "boolean",
            "date",
            "timestamp",
            "timestamptz",
            "geometry",
            "jsonb"
          ]
        },
        "formats": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 64 }
        },
        "nullable": { "type": "boolean", "default": true }
      }
    },
    "indexDef": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/postgresIdentifier" }
    },
    "foreignKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["columns", "references"],
      "properties": {
        "columns": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/postgresIdentifier" }
        },
        "references": {
          "type": "object",
          "additionalProperties": false,
          "required": ["table", "columns"],
          "properties": {
            "table": { "$ref": "#/$defs/postgresIdentifier" },
            "columns": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/postgresIdentifier" }
            }
          }
        }
      }
    },
    "derivedTable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "columns"],
      "properties": {
        "name": { "$ref": "#/$defs/postgresIdentifier" },
        "description": { "type": "string", "maxLength": 2000 },
        "columns": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/column" }
        },
        "indexes": {
          "type": "array",
          "description": "Btree or GiST (geometry) indexes created at load time.",
          "items": { "$ref": "#/$defs/indexDef" }
        },
        "foreign_keys": {
          "type": "array",
          "items": { "$ref": "#/$defs/foreignKey" }
        }
      }
    }
  }
}
