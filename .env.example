# Copy to ".env" and adjust. Values below match docker-compose defaults where noted.
# Never commit ".env" with real secrets.

# --- Postgres (postgis service) ---
POSTGRES_USER=opendata
POSTGRES_PASSWORD=opendata
POSTGRES_DB=opendata
# Host port when published to the host (inside Compose, services use hostname "postgres").
POSTGRES_PORT=5432

# --- App database URL (Steps 5+; default matches postgres service defaults) ---
# Inside Compose (dagster/api containers), host must be the service name "postgres":
#   DATABASE_URL=postgresql://opendata:opendata@postgres:5432/opendata
# On the host (Workflow A: docker compose up + host dagster materialize), use localhost:
DATABASE_URL=postgresql://opendata:opendata@127.0.0.1:5432/opendata
# Role that owns loaded tables (scripts/provision_roles.py ALTER DEFAULT PRIVILEGES FOR ROLE).
# OPENDATA_PG_OWNER_ROLE=opendata

# --- MinIO (S3-compatible landing zone) ---
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Landing zone client env (boto3-compatible; used by extractors in later steps).
# Defaults align with MinIO root credentials above; override if you use separate app keys.
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=opendata-landing

# Create the bucket once (MinIO Console http://localhost:9001 or `mc mb local/opendata-landing`).

# Landing / load backends (Step 18; default local + copy_local for lite Compose).
# OPENDATA_LANDING_BACKEND=local
# OPENDATA_LANDING_BACKEND=s3
# OPENDATA_LOAD_BACKEND=copy_local
# OPENDATA_LOAD_BACKEND=s3_copy_rds   # AWS RDS with aws_s3 extension (profile: standard)
# OPENDATA_S3_COPY_REGION=us-east-1   # optional; defaults to AWS_DEFAULT_REGION
# Standard profile POC (see examples/definitions.poc.yml, docs/deployment/aws-first-deploy.md):
# OPENDATA_LANDING_BACKEND=s3
# OPENDATA_DERIVED_RUNNER=docker
# OPENDATA_EXTRACT_EXECUTOR=local

# --- Definitions loader (Step 3+: pipeline.definitions.load_definitions) ---
# Path to deployment manifest (definitions.yml) inside the container filesystem.
OPENDATA_DEFINITIONS_MANIFEST_PATH=/workspace/examples/definitions.local.yml
# Writable directory where each definitions[].name repo is cloned (wiped per load today).
OPENDATA_DEFINITIONS_WORK_DIR=/workspace/data/definitions_work

# Future entrypoint flag: re-clone definition repos on container start (not wired in Step 4).
DEFINITIONS_REFRESH_ON_START=false

# Dagster (Step 6): ``pipeline.dagster_defs`` / ``pipeline.factory.build_dagster_definitions``.
# auto — run ``load_definitions`` from the manifest; on failure use the checked-in ``examples/definition-repo``.
# clone — require a successful clone (fail fast). embedded — skip git; always use the example tree.
# OPENDATA_DAGSTER_DEFINITION_LOAD=auto
# Materialize mode: auto (skeleton without DATABASE_URL), skeleton, or full extract→load.
# OPENDATA_DAGSTER_MATERIALIZE=auto

# --- Dagster Slack (Step 12: optional run-failure sensor; disabled unless both are set) ---
# Bot token and channel for ``dagster-slack`` ``make_slack_on_run_failure_sensor`` (sensor starts STOPPED).
# OPENDATA_SLACK_TOKEN=xoxb-...
# OPENDATA_SLACK_CHANNEL=#opendata-alerts
# Optional: base URL for Dagster UI links in Slack messages.
# OPENDATA_SLACK_WEBSERVER_BASE_URL=http://localhost:3000

# dbt (Step 9): profiles for `examples/definition-repo/models` (Compose sets these on the dagster service).
# DBT_PROFILES_DIR=/workspace/examples/definition-repo/models/dbt_profile
# DBT_TARGET_SCHEMA=ex_housing

# --- Published ports for app services ---
DAGSTER_PORT=3000
API_PORT=8000

# --- Read-only API (Step 11: FastAPI + per-role pools + optional API keys) ---
# JSON object mapping Postgres role name → libpq URI. Required for real query execution (otherwise routes return 503).
# Roles are ``opendata_public_read`` and ``opendata_<schema>_read`` values from provisioning.
# OPENDATA_API_ROLE_DSNS={"opendata_public_read":"postgresql://opendata_public_read:changeme@postgres:5432/opendata","opendata_ex_housing_read":"postgresql://opendata_ex_housing_read:changeme@postgres:5432/opendata"}
#
# API key lookup (``Authorization: Bearer odk_…``) uses this DSN when set, else ``DATABASE_URL`` (must allow SELECT on opendata_auth.api_keys).
# OPENDATA_API_KEYS_LOOKUP_DSN=postgresql://opendata:opendata@postgres:5432/opendata

# Optional: tag for the locally built framework image (both dagster and api services).
# OPENDATA_IMAGE_NAME=opendata-etl:local

# --- Source credentials (named in definitions.yml / datasets; resolved at runtime) ---
# Prefix: SOURCE_CREDENTIAL_<UPPER_NAME>_… (credential "fake_source_reader" → FAKE_SOURCE_READER).
#
# kind: aws_profile — requires SOURCE_CREDENTIAL_FAKE_SOURCE_READER_AWS_PROFILE
# kind: aws_iam — optional SOURCE_CREDENTIAL_…_AWS_PROFILE; else default credential chain
# kind: env — SOURCE_CREDENTIAL_…_ACCESS_KEY_ID, _SECRET_ACCESS_KEY, optional _SESSION_TOKEN
# kind: aws_ssm — SOURCE_CREDENTIAL_…_SSM_PARAMETER (JSON with aws_access_key_id / aws_secret_access_key)
# kind: minio — explicit keys + optional SOURCE_CREDENTIAL_…_S3_ENDPOINT_URL for S3 source reads
# kind: none — public bucket reads (unsigned S3 client); no secrets
#
# Optional on any non-none kind: assume_role_arn in definitions.yml (STS after base session).
